# ---------------------------------------------------------------------------
# Copy to .env.local and fill in. Never commit the filled copy.
# ---------------------------------------------------------------------------

# Auth.js session encryption. Generate with: npx auth secret
AUTH_SECRET=

# GitHub App — NOT a classic OAuth App.
# A classic app grants read AND write to every private repo; SPEC forbids it.
#
# Create at: https://github.com/settings/apps/new
#   Permissions:        Repository → Contents: Read-only
#   Callback URL:       http://localhost:3000/api/auth/callback/github
#   Setup URL:          http://localhost:3000/api/github/setup
#   "Request user authorization (OAuth) during installation":  UNCHECKED
#   "Expire user authorization tokens":                        CHECKED
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# The slug from the app's public page URL, used to build the install link.
NEXT_PUBLIC_GITHUB_APP_SLUG=

# Only needed when the app is served from a host Auth.js cannot infer — a
# production build on a port other than 3000, a container, a reverse proxy.
# Vercel is detected automatically. Without it `auth()` fails every request
# with UntrustedHost and every page renders as signed out.
# AUTH_TRUST_HOST=true

# Neon — two strings, and they are not interchangeable.
#   DATABASE_URL  pooled,   used at runtime
#   DIRECT_URL    unpooled, used for migrations (the pooler fails on advisory locks)
DATABASE_URL=
DIRECT_URL=
